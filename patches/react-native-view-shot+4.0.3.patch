+static UIScrollView *RNViewShotFindScrollView(UIView *view)
+{
+  if ([view isKindOfClass:[UIScrollView class]]) {
+    return (UIScrollView *)view;
+  }
+
+  for (UIView *subview in view.subviews) {
+    UIScrollView *scrollView = RNViewShotFindScrollView(subview);
+    if (scrollView) {
+      return scrollView;
+    }
+  }
+
+  return nil;
+}
