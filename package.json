{
  "name": "create-expo-stack-template",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "authors": [
    {
      "name": "react-native-reusables",
      "url": "https://react-native-reusables.com"
    }
  ],
  "homepage": "https://github.com/Super1WindCloud",
  "scripts": {
    "android": "expo run:android",
    "ios": "expo run:ios",
    "start": "expo start",
    "startc": "expo start -c ",
    "prebuild": "expo prebuild",
    "apk": "eas build -p android --profile production --local",
    "ipa": "eas build -p ios --profile production --local",
    "lint": "eslint \"**/*.{js,jsx,ts,tsx}\" && prettier -c \"**/*.{js,jsx,ts,tsx,json}\"",
    "format": "eslint \"**/*.{js,jsx,ts,tsx}\" --fix && prettier \"**/*.{js,jsx,ts,tsx,json}\" --write",
    "web": "expo start --web",
    "static": "expo export && expo serve",
    "shadcn": "npx @react-native-reusables/cli@latest add -o -a -y",
    "taze": "npx taze major -w -x tailwindcss",
    "migrate": "biome migrate  eslint --write   && biome migrate  prettier --write",
    "fix": "biome check --fix",
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "align": "expo install --fix",
    "testflight": "npx testflight",
    "deploy": "npx eas-cli deploy",
    "commitlint": "commitlint --edit"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.2.4",
    "@rn-primitives/accordion": "^1.4.0",
    "@rn-primitives/alert-dialog": "^1.4.0",
    "@rn-primitives/aspect-ratio": "^1.4.0",
    "@rn-primitives/avatar": "^1.4.0",
    "@rn-primitives/checkbox": "^1.4.0",
    "@rn-primitives/collapsible": "^1.4.0",
    "@rn-primitives/context-menu": "^1.4.0",
    "@rn-primitives/dialog": "^1.4.0",
    "@rn-primitives/dropdown-menu": "^1.4.0",
    "@rn-primitives/hover-card": "^1.4.0",
    "@rn-primitives/label": "^1.4.0",
    "@rn-primitives/menubar": "^1.4.0",
    "@rn-primitives/popover": "^1.4.0",
    "@rn-primitives/progress": "^1.4.0",
    "@rn-primitives/radio-group": "^1.4.0",
    "@rn-primitives/select": "^1.4.0",
    "@rn-primitives/separator": "^1.4.0",
    "@rn-primitives/slot": "^1.4.0",
    "@rn-primitives/switch": "^1.4.0",
    "@rn-primitives/tabs": "^1.4.0",
    "@rn-primitives/toggle": "^1.4.0",
    "@rn-primitives/toggle-group": "^1.4.0",
    "@rn-primitives/tooltip": "^1.4.0",
    "@supabase/supabase-js": "^2.106.1",
    "@tanstack/react-query": "^5.100.13",
    "babel-preset-expo": "^56.0.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "expo": "^56.0.3",
    "expo-constants": "^56.0.14",
    "expo-linking": "^56.0.11",
    "expo-localization": "^56.0.6",
    "expo-router": "^56.2.5",
    "expo-status-bar": "^56.0.4",
    "expo-system-ui": "^56.0.5",
    "expo-web-browser": "^56.0.5",
    "i18next": "^26.2.0",
    "lucide-react-native": "^1.16.0",
    "nativewind": "^4.2.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.76.1",
    "react-i18next": "^17.0.8",
    "react-native": "^0.85.3",
    "react-native-css-interop": "^0.2.4",
    "react-native-gesture-handler": "^2.31.2",
    "react-native-reanimated": "^4.3.1",
